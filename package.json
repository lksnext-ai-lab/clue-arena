{
  "name": "clue-arena-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "NODE_ENV=production node --import tsx src/server.ts",
    "start:dev": "NODE_ENV=production DISABLE_AUTH=true  node --import tsx src/server.ts",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:runtime": "node --import tsx src/lib/db/migrate.ts",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
