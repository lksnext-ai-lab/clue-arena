    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.39.3",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "genkit": "^1.16.1",
    "genkitx-ollama": "^1.16.1",
    "lucide-react": "^0.479.0",
    "mermaid": "^11.13.0",
    "next": "^15.5.12",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.3",
    "pino": "^10.3.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
