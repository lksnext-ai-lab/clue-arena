# ─── Dev mode ────────────────────────────────────────────────────────────────
# Set both to "true" to skip OIDC in local development.
# NEVER set to true in production.
DISABLE_AUTH=false
NEXT_PUBLIC_DISABLE_AUTH=false

# Auth.js
AUTH_SECRET=                    # Secreto para firmar cookies de sesión Auth.js (openssl rand -hex 32)

# Firebase Authentication (cliente web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# Lista explícita de proveedores activos para la UI de login, separada por comas.
# Ej.: password,google.com o google.com,microsoft.com
NEXT_PUBLIC_FIREBASE_AUTH_PROVIDER=password,google.com

# Firebase Admin SDK (servidor)
# En Firebase App Hosting suele bastar con las credenciales por defecto del entorno.
# Para desarrollo local, puedes usar una cuenta de servicio explícita.
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Bootstrap admin: el primer login con este email recibe rol 'admin' automáticamente.
# Solo se aplica si el usuario NO existe aún en la BD (idempotente).
# Recomendado en el setup inicial de cualquier entorno vacío.
BOOTSTRAP_ADMIN_EMAIL=          # p.ej: tu-email@organizacion.com

# Base de datos SQLite
DATABASE_URL=./data/clue-arena.db
# Ruta SQLite usada por docker compose dentro del contenedor.
DOCKER_DATABASE_URL=/app/data/clue-arena.db

# MattinAI
MATTIN_API_URL=https://mattin.lksnext.com
MATTIN_API_KEY=mattin_<api-key>

# MCP Server (token para autenticar llamadas entrantes de MattinAI)
MCP_AUTH_TOKEN=                 # Token Bearer aleatorio y seguro

# ─── Agente local (RFC F006) ──────────────────────────────────────────────────
# AGENT_BACKEND=local activa el backend Genkit (desarrollo / CI / staging).
# Omitir o poner "mattin" para usar MattinAI en producción.
AGENT_BACKEND=mattin            # "local" | "mattin" (default)

# Modelo LLM para el agente local. Opciones:
#   googleai/gemini-2.5-flash  → Google AI Studio (requiere GEMINI_API_KEY)
#   ollama/llama3.2                → Ollama local (requiere OLLAMA_SERVER_URL)
#   ollama/qwen2.5-coder           → Ollama local, buen tool-calling
GENKIT_MODEL=googleai/gemini-3-flash-preview

# Clave de Google AI Studio. Solo necesaria si GENKIT_MODEL=googleai/*
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=                 # AIza...

# URL del servidor Ollama. Solo necesaria si GENKIT_MODEL=ollama/*
# Para activar Ollama, descomentar el plugin en src/lib/ai/genkit.ts
OLLAMA_SERVER_URL=http://localhost:11434

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
